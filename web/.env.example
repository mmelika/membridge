# Same Supabase project the CLI's baked lib/backend.json points at.
# Both values are safe to expose to browsers: the anon key is designed for
# client apps and row-level security is what actually protects the data.
NEXT_PUBLIC_SUPABASE_URL=https://<ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon public key>
