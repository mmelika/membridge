{
  "name": "@membridgeai/membridge",
  "version": "0.1.4",
  "description": "Shared memory across your AI coding tools. A tiny background daemon that watches Claude Code, Codex and any other agent's session logs, distills a brief per-project memory, and syncs it into the context files every tool reads (CLAUDE.md, AGENTS.md, ...).",
  "keywords": [
    "ai",
    "claude-code",
    "codex",
    "agents",
    "memory",
    "context",
    "sync",
    "developer-tools"
  ],
  "license": "FSL-1.1-ALv2",
  "author": "Andrew Brown & Marco Melika",
  "homepage": "https://github.com/MembridgeAi/membridge#readme",
  "bugs": {
    "url": "https://github.com/MembridgeAi/membridge/issues"
  },
  "bin": {
    "membridge": "bin/membridge.js"
  },
  "main": "lib/scan.js",
  "files": [
    "bin",
    "lib",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "node test/run-tests.js",
    "prepublishOnly": "npm install --no-save --no-audit --no-fund @modelcontextprotocol/sdk@^1 zod@^4 && npm test",
    "start": "node bin/membridge.js start",
    "app": "node scripts/prepare-app.js && electron app",
    "dist:mac": "node scripts/prepare-app.js && electron-builder --mac --publish never",
    "dist:win": "node scripts/prepare-app.js && electron-builder --win --publish never"
  },
  "build": {
    "appId": "com.membridge.app",
    "productName": "MemBridge",
    "directories": {
      "app": "app",
      "output": "dist"
    },
    "afterPack": "scripts/afterPack.js",
    "mac": {
      "target": [
        {
          "target": "zip",
          "arch": [
            "arm64"
          ]
        }
      ],
      "artifactName": "MemBridge-${version}-${arch}.${ext}",
      "category": "public.app-category.developer-tools",
      "icon": "app/assets/icon.png"
    },
    "win": {
      "target": [
        "zip"
      ],
      "icon": "app/assets/icon.png"
    }
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MembridgeAi/membridge.git"
  },
  "devDependencies": {
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3"
  },
  "dependencies": {
    "libsodium-wrappers": "^0.8.4"
  }
}
